# Copy this to .env and fill in your values
# .env is gitignored - never commit secrets

DATABASE_URL=postgresql+asyncpg://raguser:ragpassword@localhost:5432/ragdb
REDIS_URL=redis://localhost:6379
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

APP_ENV=development
LOG_LEVEL=INFO

# CORS — allowed frontend origins. Default: http://localhost:7860 (Gradio UI).
# In production set this to your actual frontend URL (JSON array format).
# CORS_ALLOW_ORIGINS=["https://your-app.example.com"]

# Rate limiting (auth endpoints)
# These match the defaults in app/config.py. Override only if needed.
AUTH_REGISTER_RATE_LIMIT_REQUESTS=5
AUTH_REGISTER_RATE_LIMIT_WINDOW=300
AUTH_TOKEN_RATE_LIMIT_REQUESTS=10
AUTH_TOKEN_RATE_LIMIT_WINDOW=60

# Corporate / TLS-intercepting proxy networks only
# Set SYSTEM_CA_BUNDLE to your system's CA certificate bundle so the API
# container can download HuggingFace models through the proxy.
# Then start with: make up-corporate  (instead of: docker compose up -d)
#
# Fedora / RHEL:   SYSTEM_CA_BUNDLE=/etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem
# Ubuntu / Debian: SYSTEM_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
# macOS:           SYSTEM_CA_BUNDLE=/etc/ssl/cert.pem
# SYSTEM_CA_BUNDLE=

# Only needed if the CA bundle approach above does NOT work for your proxy.
# Pre-download models with 'make download-models' first, then uncomment.
# TRANSFORMERS_OFFLINE=1
# HF_DATASETS_OFFLINE=1
